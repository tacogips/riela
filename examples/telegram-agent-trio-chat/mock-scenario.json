{
  "route-message": {
    "provider": "scenario-mock",
    "model": "gpt-5.4-mini",
    "when": {
      "target_yui": true,
      "target_mika": false,
      "target_rina": false
    },
    "payload": {
      "target": "yui",
      "reason": "No persona was named, so Yui is the default responder.",
      "target_yui": true,
      "target_mika": false,
      "target_rina": false
    }
  },
  "yui-codex": {
    "provider": "scenario-mock",
    "model": "gpt-5.4-mini",
    "when": {
      "handoff_mika": true,
      "handoff_rina": false
    },
    "payload": {
      "replyText": "承知しました。私の見立てでは、通常の整理と進行はYui、場の見え方はMika、技術的な見落としはRinaに分けると、会話が落ち着いて回ります。@Mika、この役割分担はTelegram上でも親しみやすく見えるでしょうか？",
      "handoff_mika": true,
      "handoff_rina": false
    }
  },
  "mika-claude": {
    "provider": "scenario-mock",
    "model": "claude-sonnet-4-5",
    "when": {
      "handoff_yui": false,
      "handoff_rina": true
    },
    "payload": {
      "replyText": "いいじゃん、それアリ。Yuiは大人っぽく整えてくれるし、Mikaは明るくノリを作れるし、Rinaは冷静に締めてくれるから、3人のキャラ差がぱっと伝わる。@Rina、技術的に危ないとこある？",
      "handoff_yui": false,
      "handoff_rina": true
    }
  },
  "rina-cursor": {
    "provider": "scenario-mock",
    "model": "gpt-5.5",
    "when": {
      "handoff_yui": false,
      "handoff_mika": false
    },
    "payload": {
      "replyText": "結論。入口は一つでいい。ただし routing、memory、reply identity は persona ごとに分離するべき。handoff 上限とログ確認を固定すれば、議論の循環は制御できる。",
      "handoff_yui": false,
      "handoff_mika": false
    }
  }
}

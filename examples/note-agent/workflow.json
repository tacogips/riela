{
  "workflowId": "note-agent",
  "description": "Answer a note chat request through bounded Graph-RAG retrieval and exact note_id citations.",
  "defaults": {
    "maxLoopIterations": 3,
    "nodeTimeoutMs": 120000
  },
  "prompts": {
    "workerSystemPromptTemplate": "Return concise JSON only. Cite only exact note_id values returned by the bounded Riela Note retrieval steps."
  },
  "entryStepId": "retrieve-notes",
  "nodes": [
    {
      "id": "retrieve-notes",
      "addon": {
        "name": "riela/note-search",
        "version": "1",
        "config": {
          "noteRoot": "{{noteRoot}}",
          "query": "{{workflowInput.query}}",
          "includeLinked": false,
          "limit": "{{workflowInput.limit}}"
        }
      }
    },
    {
      "id": "walk-note-graph",
      "addon": {
        "name": "riela/note-graph-neighbors",
        "version": "1",
        "config": {
          "noteRoot": "{{noteRoot}}",
          "depth": 5,
          "limit": 16
        },
        "inputs": {
          "noteIds": "{{_rielaInput.latest.payload.noteIds}}"
        }
      }
    },
    {
      "id": "get-source-notes",
      "addon": {
        "name": "riela/note-get",
        "version": "1",
        "config": {
          "noteRoot": "{{noteRoot}}"
        },
        "inputs": {
          "noteIds": "{{_rielaInput.latest.payload.retrievalNoteIds}}",
          "graphEvidence": "{{_rielaInput.latest.payload.results}}"
        }
      }
    },
    {
      "id": "answer-with-citations",
      "nodeFile": "nodes/node-answer-with-citations.json"
    },
    {
      "id": "workflow-output",
      "kind": "output",
      "nodeFile": "nodes/node-workflow-output.json"
    }
  ],
  "steps": [
    {
      "id": "retrieve-notes",
      "nodeId": "retrieve-notes",
      "role": "worker",
      "transitions": [
        {
          "toStepId": "walk-note-graph"
        }
      ]
    },
    {
      "id": "walk-note-graph",
      "nodeId": "walk-note-graph",
      "role": "worker",
      "transitions": [
        {
          "toStepId": "get-source-notes"
        }
      ]
    },
    {
      "id": "get-source-notes",
      "nodeId": "get-source-notes",
      "role": "worker",
      "transitions": [
        {
          "toStepId": "answer-with-citations"
        }
      ]
    },
    {
      "id": "answer-with-citations",
      "nodeId": "answer-with-citations",
      "role": "worker",
      "transitions": [
        {
          "toStepId": "workflow-output"
        }
      ]
    },
    {
      "id": "workflow-output",
      "nodeId": "workflow-output",
      "role": "worker"
    }
  ]
}

{
  "riela-manager": {
    "provider": "scenario-mock",
    "model": "claude-haiku-4-5",
    "when": {
      "always": true
    },
    "payload": {
      "stage": "root-dispatch",
      "backendPolicy": "riela-on-claude-code"
    }
  },
  "main-riela": {
    "provider": "scenario-mock",
    "model": "claude-haiku-4-5",
    "when": {
      "always": true
    },
    "payload": {
      "stage": "delivery-dispatch",
      "delegationPolicy": "codex-only-for-coding"
    }
  },
  "workflow-input": {
    "provider": "scenario-mock",
    "model": "claude-haiku-4-5",
    "when": {
      "always": true
    },
    "payload": {
      "normalizedRequest": "Add an examples workflow that demonstrates mixed backends.",
      "constraints": [
        "Keep riela on claude-code",
        "Use codex for code production",
        "Make the workflow directly reusable as a reference"
      ],
      "acceptanceChecks": [
        "workflow validates from ./examples",
        "backend split is explicit in node files"
      ]
    }
  },
  "implementation-brief": {
    "provider": "scenario-mock",
    "model": "claude-haiku-4-5",
    "when": {
      "always": true
    },
    "payload": {
      "filesToTouch": [
        "examples/README.md",
        "examples/claude-riela-codex-coding/workflow.json"
      ],
      "implementationPlan": [
        "Create a workflow bundle under examples/",
        "Assign claude-code to riela nodes",
        "Assign codex to the coding node",
        "Provide a deterministic mock scenario"
      ],
      "verificationCommands": [
        "swift run riela workflow validate claude-riela-codex-coding --workflow-definition-dir ./examples",
        "swift run riela workflow inspect claude-riela-codex-coding --workflow-definition-dir ./examples --output json"
      ]
    }
  },
  "implement": {
    "provider": "scenario-mock",
    "model": "gpt-5.3-codex-spark",
    "when": {
      "always": true
    },
    "payload": {
      "changedFiles": [
        "examples/README.md",
        "examples/claude-riela-codex-coding/workflow.json",
        "examples/claude-riela-codex-coding/node-implement.json"
      ],
      "summary": "Created a mixed-backend reference workflow with claude-code managers and a codex implementation node.",
      "verification": ["workflow validate", "workflow inspect"],
      "risks": []
    }
  },
  "workflow-output": {
    "provider": "scenario-mock",
    "model": "claude-haiku-4-5",
    "when": {
      "always": true
    },
    "payload": {
      "summary": "Reference workflow bundle is ready under examples/ with an explicit claude-code and codex split.",
      "status": "ready",
      "changedFiles": [
        "examples/README.md",
        "examples/claude-riela-codex-coding/"
      ],
      "verification": [
        "workflow validate",
        "workflow inspect",
        "workflow run --mock-scenario"
      ],
      "risks": []
    }
  }
}

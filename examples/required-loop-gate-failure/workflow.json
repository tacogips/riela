{
  "workflowId": "required-loop-gate-failure",
  "description": "Minimal required loop workflow that demonstrates fail-closed behavior when a required review gate reports blocking findings.",
  "defaults": {
    "maxLoopIterations": 1,
    "nodeTimeoutMs": 120000
  },
  "prompts": {
    "workerSystemPromptTemplate": "Return concise structured review JSON only."
  },
  "entryStepId": "implementation-review",
  "loop": {
    "kind": "design-implement-review",
    "required": true,
    "description": "Example of required loop gate enforcement.",
    "evidence": {
      "required": true,
      "artifactRootPolicy": "runtime-owned",
      "requiredSections": [
        "verification",
        "review"
      ]
    },
    "policies": {
      "process": {
        "nestedRiela": "deny",
        "nestedCodex": "deny",
        "allowedBackends": [
          "codex-agent"
        ],
        "requiredWorkerModel": "gpt-5.5"
      },
      "redaction": {
        "secretPolicy": "summary-only",
        "storeRawStdout": false,
        "storeRawStderr": false
      }
    },
    "gates": [
      {
        "id": "implementation-review",
        "stepId": "implementation-review",
        "required": true,
        "acceptWhen": {
          "decision": "accepted",
          "maxHighFindings": 0,
          "maxMediumFindings": 0
        }
      }
    ]
  },
  "nodes": [
    {
      "id": "implementation-review",
      "nodeFile": "nodes/node-implementation-review.json"
    }
  ],
  "steps": [
    {
      "id": "implementation-review",
      "nodeId": "implementation-review",
      "role": "worker",
      "loop": {
        "role": "gate",
        "gateId": "implementation-review",
        "evidenceTags": [
          "review",
          "blocking-findings"
        ],
        "recordsVerification": true
      }
    }
  ]
}

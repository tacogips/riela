{
  "id": "gmail-latest-mail-hourly-to-workflow",
  "sourceId": "gmail-latest-mail-hourly-cron",
  "outputDestinations": ["telegram-gateway-persona-replies"],
  "workflowName": "gmail-latest-mail-digest-telegram",
  "match": {
    "eventType": "cron.tick"
  },
  "inputMapping": {
    "mode": "template",
    "template": {
      "request": "Fetch the latest Gmail messages, summarize only first-time-seen messages, and post a Telegram digest.",
      "accountId": "gmail",
      "gmailSearchQuery": "in:inbox",
      "maxMessages": 10,
      "stateFile": ".riela-data/gmail-latest-mail-digest-telegram/state.json",
      "scheduledAt": "{{event.input.scheduledAt}}",
      "firedAt": "{{event.input.firedAt}}",
      "timezone": "{{event.input.timezone}}",
      "replyTarget": "{{event.input.replyTarget}}"
    },
    "mirrorToHumanInput": false
  },
  "execution": {
    "async": false,
    "dedupeWindowMs": 300000,
    "maxConcurrentPerKey": 1,
    "concurrencyKey": "{{event.sourceId}}"
  },
  "taskPlanning": {
    "enabled": false
  },
  "mailboxBridge": {
    "output": {
      "reply": {
        "mode": "none"
      },
      "progress": {
        "mode": "none"
      },
      "control": {
        "mode": "none"
      }
    }
  }
}

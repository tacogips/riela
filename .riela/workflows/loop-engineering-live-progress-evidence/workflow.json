{
  "workflowId": "loop-engineering-live-progress-evidence",
  "description": "Persist loop evidence during live workflow progress saves, not only final run persistence.",
  "defaults": {
    "maxLoopIterations": 2,
    "nodeTimeoutMs": 1200000
  },
  "entryStepId": "intake-or-plan",
  "nodes": [
    {
      "id": "intake-or-plan",
      "nodeFile": "nodes/node-intake-or-plan.json"
    },
    {
      "id": "work",
      "nodeFile": "nodes/node-work.json"
    },
    {
      "id": "review",
      "nodeFile": "nodes/node-review.json"
    },
    {
      "id": "workflow-output",
      "nodeFile": "nodes/node-workflow-output.json"
    }
  ],
  "steps": [
    {
      "id": "intake-or-plan",
      "nodeId": "intake-or-plan",
      "role": "worker",
      "transitions": [
        {
          "toStepId": "work"
        }
      ]
    },
    {
      "id": "work",
      "nodeId": "work",
      "role": "worker",
      "transitions": [
        {
          "toStepId": "review"
        }
      ]
    },
    {
      "id": "review",
      "nodeId": "review",
      "role": "worker",
      "transitions": [
        {
          "toStepId": "workflow-output"
        }
      ]
    },
    {
      "id": "workflow-output",
      "nodeId": "workflow-output",
      "role": "worker"
    }
  ]
}

if has nix; then
    use flake .
fi

# Load secrets from kinko vault.
# Use direnv-aware export from kinko.
if command -v kinko >/dev/null 2>&1; then
  eval "$(kinko direnv export)"
fi

# Compatibility aliases for the example event-source configs.
export RIELA_TELEGRAM_BOT_TOKEN="${RIELA_TELEGRAM_BOT_TOKEN:-${RIEL_TELEGRAM_BOT_TOKEN:-}}"
export RIELA_TELEGRAM_BOT_ID="${RIELA_TELEGRAM_BOT_ID:-${RIEL_TELEGRAM_BOT_ID:-}}"
export RIELA_TELEGRAM_CHAT_ID="${RIELA_TELEGRAM_CHAT_ID:-${RIEL_TELEGRAM_CHAT_ID:-}}"
export RIELA_TELEGRAM_YUI_BOT_TOKEN="${RIELA_TELEGRAM_YUI_BOT_TOKEN:-${RIEL_TELEGRAM_YUI_BOT_TOKEN:-}}"
export RIELA_TELEGRAM_MIKA_BOT_TOKEN="${RIELA_TELEGRAM_MIKA_BOT_TOKEN:-${RIEL_TELEGRAM_MIKA_BOT_TOKEN:-}}"
export RIELA_TELEGRAM_RINA_BOT_TOKEN="${RIELA_TELEGRAM_RINA_BOT_TOKEN:-${RIEL_TELEGRAM_RINA_BOT_TOKEN:-}}"
export RIELA_DISCORD_BOT_TOKEN="${RIELA_DISCORD_BOT_TOKEN:-${RIEL_DISCORD_BOT_TOKEN:-}}"
export RIELA_DISCORD_APPLICATION_ID="${RIELA_DISCORD_APPLICATION_ID:-${RIEL_DISCORD_APPLICATION_ID:-}}"
export RIELA_DISCORD_SERVER_ID="${RIELA_DISCORD_SERVER_ID:-${RIEL_DISCORD_SERVER_ID:-}}"
export RIELA_DISCORD_CHANNEL_ID="${RIELA_DISCORD_CHANNEL_ID:-${RIEL_DISCORD_CHANNEL_ID:-}}"

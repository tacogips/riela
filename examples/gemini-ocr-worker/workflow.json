{
  "workflowId": "gemini-ocr-worker",
  "description": "Extract text from an inline JPEG image through the built-in Gemini SDK worker add-on.",
  "defaults": {
    "maxLoopIterations": 3,
    "nodeTimeoutMs": 180000
  },
  "entryStepId": "ocr-image",
  "nodes": [
    {
      "id": "ocr-image",
      "addon": {
        "name": "riela/gemini-sdk-worker",
        "version": "1",
        "config": {
          "model": "gemini-3.5-flash",
          "systemPromptTemplate": "You are an OCR engine. Return only the exact visible text from the image.",
          "promptTemplate": "Extract the exact text from the attached image.",
          "inlineDataParts": [
            {
              "mimeType": "image/jpeg",
              "dataBase64": ""
            }
          ]
        },
        "env": {
          "GOOGLE_API_KEY": {
            "fromEnv": "GOOGLE_API_KEY",
            "required": false
          },
          "GEMINI_API_KEY": {
            "fromEnv": "GEMINI_API_KEY",
            "required": false
          }
        }
      }
    }
  ],
  "steps": [
    {
      "id": "ocr-image",
      "nodeId": "ocr-image",
      "role": "worker"
    }
  ]
}

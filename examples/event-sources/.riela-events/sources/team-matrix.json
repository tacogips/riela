{
  "id": "team-matrix",
  "kind": "matrix",
  "provider": "matrix",
  "homeserverUrlEnv": "RIELA_MATRIX_HOMESERVER_URL",
  "accessTokenEnv": "RIELA_MATRIX_ACCESS_TOKEN",
  "userId": "@riela:matrix.example",
  "rooms": [
    {
      "roomId": "!release:matrix.example",
      "alias": "#release:matrix.example"
    },
    {
      "roomId": "!persona:matrix.example",
      "alias": "#persona:matrix.example"
    }
  ],
  "sync": {
    "pollTimeoutMs": 30000,
    "sinceTokenPath": "tmp/matrix/team-matrix-sync.json"
  },
  "history": {
    "maxMessages": 100,
    "maxBytes": 131072,
    "maxAgeMs": 2592000000,
    "scope": "thread-or-room",
    "includeOwnMessages": false
  },
  "attachments": {
    "downloadText": true,
    "maxBytes": 65536,
    "allowedMimeTypes": ["text/plain", "text/markdown", "application/json"]
  },
  "replyBots": {
    "yui": {
      "accessTokenEnv": "RIELA_MATRIX_YUI_ACCESS_TOKEN"
    },
    "mika": {
      "accessTokenEnv": "RIELA_MATRIX_MIKA_ACCESS_TOKEN"
    },
    "rina": {
      "accessTokenEnv": "RIELA_MATRIX_RINA_ACCESS_TOKEN"
    }
  }
}

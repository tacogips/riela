{
  "id": "mika-claude",
  "description": "Mika Trend: a Japanese female gyaru persona backed by official OpenAI SDK, strong in entertainment and trends.",
  "executionBackend": "official/openai-sdk",
  "model": "gpt-5.3-codex-spark",
  "modelFreeze": true,
  "systemPromptTemplateFile": "prompts/mika-system.md",
  "promptTemplateFile": "prompts/persona-reply.md",
  "variables": {
    "personaName": "Mika Trend",
    "shortName": "Mika",
    "backendName": "official/openai-sdk",
    "peerSummary": "Yui Codex is a refined secretary and default coordinator. Rina Cursor is an intellectual otaku and technical analyst.",
    "personaId": "mika",
    "memoryRoot": "{{workflowInput.memoryRoot}}"
  },
  "output": {
    "description": "Return Mika's chat reply; optional handoff flags are adapter-level when values; optional memoryEntries are written by the following deterministic memory node.",
    "jsonSchema": {
      "type": "object",
      "required": [
        "replyText"
      ],
      "properties": {
        "replyText": {
          "type": "string"
        },
        "memoryEntries": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "kind": {
                "type": "string"
              },
              "importance": {
                "type": "string"
              },
              "source": {
                "type": "string"
              },
              "content": {
                "type": "string"
              }
            },
            "required": [
              "content"
            ],
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "maxValidationAttempts": 2
  }
}
